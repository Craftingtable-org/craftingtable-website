# Frontend (Vite) — optional absolute API origin for production (omit in dev; use Vite proxy)
# VITE_API_BASE_URL=https://api.example.com
# Port for local API proxy (must match server PORT, default 3001)
# VITE_API_PORT=3001

# BuiltByBit proxy (existing site feature)
# BBB_API_TOKEN=

# Schematic API (see server/.env.example)
# REDIS_URL=redis://127.0.0.1:6379
# VOID_WORLD_PATH=/absolute/path/to/void-world-bedrock.mcworld
